// Testing sessions for agents
model AiEvaluationSession {
  id                     String    @id @default(cuid())
  userId                 String
  agentId                String? // nullable so SetNull can preserve history when the agent is deleted
  title                  String
  description            String?   @db.Text
  status                 String // "draft", "in_progress", "completed", "archived"
  summary                String?   @db.Text
  improvementSuggestions Json?
  // { avgFaithfulness, avgGroundedness, avgRelevance, scoredLogCount,
  //   judgeProvider, judgeModel, scoredAt, totalScoringCostUsd }
  metricSummary          Json?
  startedAt              DateTime?
  completedAt            DateTime?
  metadata               Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  user               User                  @relation("AiEvaluationSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  agent              AiAgent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  logs               AiEvaluationLog[]
  experimentVariants AiExperimentVariant[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@map("ai_evaluation_session")
}

// Per-turn evaluation logs
model AiEvaluationLog {
  id                String   @id @default(cuid())
  sessionId         String
  messageId         String?
  sequenceNumber    Int
  eventType         String // "user_input", "ai_response", "capability_call", "capability_result", "error"
  content           String?  @db.Text
  inputData         Json?
  outputData        Json?
  capabilitySlug    String?
  executionTimeMs   Int?
  tokenUsage        Json?
  metadata          Json?
  // Named-metric scores attached to ai_response logs by the judge LLM at
  // completion / rescore time. Null until scored. Faithfulness can stay
  // null even after scoring when the response had no inline citations.
  faithfulnessScore Float?
  groundednessScore Float?
  relevanceScore    Float?
  // { faithfulness: { reasoning }, groundedness: { reasoning },
  //   relevance: { reasoning } } — display-only.
  judgeReasoning    Json?
  createdAt         DateTime @default(now())

  // Relations
  session AiEvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message AiMessage?          @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([messageId])
  @@index([eventType])
  @@map("ai_evaluation_log")
}

// ---------------------------------------------------------------------------
// Dataset-driven evaluations (Phase 1)
// ---------------------------------------------------------------------------

/// A curated collection of test cases run against an agent (or workflow).
/// Datasets are immutable in content via `contentHash` — edits change the
/// hash, which makes them visible (but not destructive) to historical runs.
model AiDataset {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?  @db.Text
  // Free-text tags for filtering. Mirrors the AiKnowledgeDocument tag
  // pattern; lower-case, no separate tag table.
  tags        String[] @default([])
  caseCount   Int      @default(0)
  // SHA-256 of the normalised case array (positions sorted, JSON-stringified).
  // Pinned on every AiEvaluationRun so an edit doesn't silently invalidate
  // historical run comparisons.
  contentHash String
  // Provenance: how this dataset was created — 'upload' (CSV/JSONL),
  // 'manual' (created case-by-case in UI), 'synthetic' (Phase 2 LLM gen),
  // 'conversation_capture' (Phase 2 trace-to-dataset, conversation source),
  // 'workflow_capture' (Phase 2 trace-to-dataset, workflow execution source).
  source      String   @default("upload")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User?             @relation("AiDatasetUser", fields: [userId], references: [id], onDelete: SetNull)
  cases          AiDatasetCase[]
  evaluationRuns AiEvaluationRun[]
  experiments    AiExperiment[]    @relation("AiExperimentDataset")

  @@index([userId, updatedAt])
  @@map("ai_dataset")
}

/// One test case inside an AiDataset. `input` is JSON to allow both
/// string-shaped (agent message) and object-shaped (workflow input vars)
/// cases without a schema split. `expectedOutput` is optional — required
/// only by reference-dependent graders (exact_match, contains, …).
model AiDatasetCase {
  id                 String  @id @default(cuid())
  datasetId          String
  // 0-based stable order inside the dataset; drives iteration & result joins.
  position           Int
  input              Json
  expectedOutput     String? @db.Text
  // Optional ground-truth retrieval contexts for RAG-style graders
  // (context_recall, context_precision) — added by Phase 2 work.
  referenceCitations Json?
  // Author-supplied case-level metadata: tags, difficulty, expectedTrajectory,
  // source ('synthetic' | 'conversation_capture' | 'workflow_capture'), …
  metadata           Json?

  dataset AiDataset                @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  results AiEvaluationCaseResult[]

  @@unique([datasetId, position])
  @@index([datasetId])
  @@map("ai_dataset_case")
}

/// A queued/running/completed evaluation run: pairs a dataset with a
/// subject (agent OR workflow), records grader configs and judge model,
/// owns the per-case results and aggregated summary. Drained by the
/// maintenance-tick worker via lease/orphan-claim semantics.
///
/// Invariant: exactly one of `agentId` / `workflowId` is non-null. Enforced
/// at the application layer (Zod) and by the worker dispatch branch — no
/// DB CHECK constraint to keep migrations portable across Postgres
/// versions / hosted offerings that restrict DDL.
model AiEvaluationRun {
  id                    String    @id @default(cuid())
  userId                String
  name                  String
  description           String?   @db.Text
  // 'agent' | 'workflow' — drives the worker's per-case dispatch.
  subjectKind           String
  agentId               String?
  workflowId            String?
  datasetId             String
  // Dataset content hash captured at submit time. The worker validates
  // this against the dataset's current hash on claim; mismatch ⇒ fail.
  datasetContentHash    String
  // Array<{ slug: string; config: unknown }> — pinned at submit time so
  // grader-registry edits don't silently invalidate historical runs.
  // Rubric prompts for `custom_rubric` are embedded here verbatim.
  metricConfigs         Json
  // Judge model resolution: explicit override > env default > system
  // chat default. Null fields = "use the resolver".
  judgeProvider         String?
  judgeModel            String?
  // Optional: for workflow subjects, which step's output to grade.
  // { kind: 'final_report' | 'last_step' | 'step_id', stepId?: string }.
  // Phase 1 UI is agent-only; this field is wired so Phase 3 ships
  // without schema rework.
  subjectOutputSelector Json?
  status                String    @default("queued") // queued | running | completed | failed | cancelled
  // { casesTotal, casesDone, casesFailed } — updated by the worker
  // every few cases (throttled to avoid hot DB writes per iteration).
  progress              Json      @default("{\"casesTotal\":0,\"casesDone\":0,\"casesFailed\":0}")
  // Per-metric aggregates after completion:
  // { metricSlugs: string[], stats: { [slug]: { mean, median, p95, passRate, scoredCount } },
  //   judgeProvider, judgeModel, completedAt, note? }
  summary               Json?
  // Phase 4 (CI gate): per-metric pass/fail thresholds the caller wants
  // to assert against. Shape: { thresholds: [{ metricSlug, minMean?, minPassRate? }] }.
  // Worker doesn't touch this; GET /runs/:id computes a `gate` block from
  // it + `summary.stats` when both are present.
  gateConfig            Json?
  totalCostUsd          Float?
  // For "Rescore as new run" — copies metrics/judge but fresh result rows.
  parentRunId           String?
  // Worker lease — mirrors processOrphanedExecutions semantics. Cleared
  // on completion or after the 5-min orphan threshold.
  lockedBy              String?
  lockedAt              DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user     User                     @relation("AiEvaluationRunUser", fields: [userId], references: [id], onDelete: Cascade)
  agent    AiAgent?                 @relation("AiEvaluationRunAgent", fields: [agentId], references: [id], onDelete: SetNull)
  workflow AiWorkflow?              @relation("AiEvaluationRunWorkflow", fields: [workflowId], references: [id], onDelete: SetNull)
  dataset  AiDataset                @relation(fields: [datasetId], references: [id])
  parent   AiEvaluationRun?         @relation("AiEvaluationRunRescore", fields: [parentRunId], references: [id], onDelete: SetNull)
  rescores AiEvaluationRun[]        @relation("AiEvaluationRunRescore")
  results  AiEvaluationCaseResult[]
  variants AiExperimentVariant[]

  @@index([userId, updatedAt])
  @@index([status, lockedAt])
  @@index([datasetId])
  @@index([agentId])
  @@index([workflowId])
  @@map("ai_evaluation_run")
}

/// Result row for a single (run × case) pair. Written by the worker
/// after subject execution + grading. `metricScores` is keyed by grader
/// slug; a missing key means the grader was skipped (e.g. `exact_match`
/// without `expectedOutput`).
model AiEvaluationCaseResult {
  id              String   @id @default(cuid())
  runId           String
  datasetCaseId   String
  // Mirror of position at result-write time; lets us order results
  // without joining the dataset case row.
  casePosition    Int
  subjectOutput   String   @db.Text
  // Token usage, citations, capability calls — whatever the agent/workflow
  // emitted that graders need to inspect.
  subjectMetadata Json?
  // { [graderSlug]: { score: number | null, passed?: boolean,
  //                   reasoning?: string, costUsd?: number } }
  metricScores    Json
  latencyMs       Int
  costUsd         Float    @default(0)
  // Set when subject execution itself failed (not when a grader skipped).
  errorCode       String?
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  run         AiEvaluationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  datasetCase AiDatasetCase   @relation(fields: [datasetCaseId], references: [id])

  @@unique([runId, casePosition])
  @@index([runId])
  @@index([datasetCaseId])
  @@map("ai_evaluation_case_result")
}
