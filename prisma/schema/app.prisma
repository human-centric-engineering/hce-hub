// Contact Form Submissions (Phase 3.5)
// Stores contact form submissions from the public website
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  @@index([read, createdAt])
  @@map("contact_submission")
}

// Feature Flags (Phase 4.4)
// Runtime feature toggle system for admin-controlled features
model FeatureFlag {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "ENABLE_BETA_FEATURES"
  enabled     Boolean  @default(false)
  description String?  @db.Text
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@index([name])
  @@map("feature_flag")
}

// Auth bootstrap marker (issue #278)
// Singleton row recording that the one-time first-user-is-admin bootstrap has
// completed. `userCreateBeforeHook` promotes the first human signup on a fresh
// database to ADMIN; this row makes that promotion fire at most once over the
// instance's lifetime. Once present, the bootstrap never fires again — even if
// every human account is later deleted and the live user count returns to zero
// — closing a re-bootstrap privilege-escalation window. Keyed by a fixed id
// (AUTH_BOOTSTRAP_ID = "singleton") so at most one row can exist.
model AuthBootstrap {
  id          String   @id // always AUTH_BOOTSTRAP_ID ("singleton")
  completedAt DateTime @default(now())

  @@map("auth_bootstrap")
}

// ─────────────────────────────────────────────────────────────────────────────
// HCE Hub — Project Coordination (Module 1). Fork-owned app models.
//
// Tables are `app_*`-prefixed to namespace against Sunrise's own app-domain
// models in this shared file (.context/app/README.md; sunrise#429). References
// to the core `User` table are plain-scalar columns with HAND-WRITTEN FK
// constraints in the migration — never a Prisma `@relation` on `User`, which
// would need a field *on* User (CUSTOMIZATION §5). Each hand-FK is drift-probed
// in lib/app/db-drift.ts (Prisma can't see it, so a future `migrate dev` could
// silently drop it). Intra-Hub relations use ordinary `@relation`.
// Feature 03 · f-data-model · t-1 (Project domain).
// ─────────────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  planning
  active
  archived
}

enum ProjectRole {
  lead
  member
  // `read_only` reserved for a later access tier (f-access) — added when used.
}

enum FeatureStatus {
  planning
  in_flight
  blocked
  shipped
}

model Project {
  id              String        @id @default(cuid())
  name            String
  hostPlatform    String // e.g. "sunrise"; other platforms are stubbed (§7)
  status          ProjectStatus @default(planning)
  repoUrls        String[]      @default([])
  leadUserId      String? // hand-FK → "user" · ON DELETE SET NULL (retain the project)
  knowledgeTagId  String? // set by f-project-admin (Sunrise KnowledgeTag); no FK
  sidekickAgentId String? // set by f-sidekick (Sunrise AiAgent); no FK
  taskCounter     Int           @default(0) // monotonic source for project-wide Task.number (f-refs)
  createdAt       DateTime      @default(now())

  members         ProjectMember[]
  features        Feature[]
  phases          Phase[]
  focusDirectives FocusDirective[]

  @@index([leadUserId])
  @@map("app_project")
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String // hand-FK → "user" · ON DELETE CASCADE (membership is the user's)
  role      ProjectRole @default(member)
  addedAt   DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId]) // one membership per user per project
  @@index([userId])
  @@map("app_project_member")
}

model Feature {
  id          String        @id @default(cuid())
  projectId   String
  slug        String? // authored short human key (e.g. "f-mcp"); per-project unique (f-refs)
  title       String
  description String?       @db.Text
  ownerUserId String? // hand-FK → "user" · ON DELETE SET NULL (retain the feature)
  status      FeatureStatus @default(planning)
  helpWanted  Boolean       @default(false)
  phaseId     String? // intra-Hub FK → app_phase · ON DELETE SET NULL (futures scaffolding, t-3)
  createdAt   DateTime      @default(now())

  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase        Phase?              @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  dependencies FeatureDependency[] @relation("FeatureDependencies") // edges where this feature depends on another
  dependents   FeatureDependency[] @relation("FeatureDependents") // edges where another feature depends on this
  tasks        Task[]

  @@unique([projectId, slug]) // human slug unique within a project (NULLs allowed while unauthored)
  @@index([projectId])
  @@index([ownerUserId])
  @@index([phaseId])
  @@map("app_feature")
}

// A directed edge: `feature` depends on `dependsOn`. Both sides cascade so an
// edge disappears when either endpoint feature is deleted.
model FeatureDependency {
  id                 String @id @default(cuid())
  featureId          String
  dependsOnFeatureId String

  feature   Feature @relation("FeatureDependencies", fields: [featureId], references: [id], onDelete: Cascade)
  dependsOn Feature @relation("FeatureDependents", fields: [dependsOnFeatureId], references: [id], onDelete: Cascade)

  @@unique([featureId, dependsOnFeatureId]) // no duplicate edges
  @@index([dependsOnFeatureId])
  @@map("app_feature_dependency")
}

// ─────────────────────────────────────────────────────────────────────────────
// Task domain — f-data-model · t-2. Same fork conventions as the block above:
// `app_*`-mapped tables, hand-written satellite FKs → core `"user"` (never a
// `@relation` on User), each drift-probed in lib/app/db-drift.ts.
// ─────────────────────────────────────────────────────────────────────────────

// The persisted task lifecycle. This is the *data* enum; the effective board
// status (e.g. surfacing a stale claim as "available") is computed later by
// f-board-view (v1-requirements §5) — it is not a stored value here.
enum TaskStatus {
  backlog
  available
  claimed
  in_pr
  merged
}

model Task {
  id              String     @id @default(cuid())
  featureId       String
  number          Int? // project-wide stable ordinal, rendered "t-N"; assigned via Project.taskCounter (f-refs)
  title           String
  description     String?    @db.Text
  status          TaskStatus @default(backlog)
  filesScope      String[]   @default([]) // paths/globs a claim expects to touch — soft-collision hint
  claimedByUserId String? // hand-FK → "user" · ON DELETE SET NULL (retain the task, drop the claimant)
  prUrl           String?
  createdAt       DateTime   @default(now())

  feature      Feature          @relation(fields: [featureId], references: [id], onDelete: Cascade)
  dependencies TaskDependency[] @relation("TaskDependencies") // edges where this task depends on another
  dependents   TaskDependency[] @relation("TaskDependents") // edges where another task depends on this
  claims       TaskClaim[]

  @@index([featureId])
  @@index([claimedByUserId])
  @@map("app_task")
}

// A directed edge: `task` depends on `dependsOn`. Both sides cascade so an edge
// disappears when either endpoint task is deleted. Like FeatureDependency,
// `@@unique` blocks only duplicate edges — self-loop / cycle acyclicity is a
// write-path concern, enforced when edges gain a writer in f-hub-capabilities
// (plan §07), not in the schema.
model TaskDependency {
  id              String @id @default(cuid())
  taskId          String
  dependsOnTaskId String

  task      Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId]) // no duplicate edges
  @@index([dependsOnTaskId])
  @@map("app_task_dependency")
}

// Append-only claim history for soft-collision detection: a row per (user
// claims task) event, closed by `releasedAt`. Multiple rows per (task, user)
// are expected over time, so there is no uniqueness — collisions are surfaced
// by the app, not blocked by the DB.
model TaskClaim {
  id         String    @id @default(cuid())
  taskId     String
  userId     String // hand-FK → "user" · ON DELETE CASCADE (the claim is the user's)
  claimedAt  DateTime  @default(now())
  releasedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("app_task_claim")
}

// ─────────────────────────────────────────────────────────────────────────────
// Futures scaffolding — f-data-model · t-3. Additive, UNCONSUMED in v1: no UI,
// no capability, no recommendation logic reads these yet. They exist so v1.x
// (sprint-aligned prioritisation, conversational focus directives, phase views)
// lands without a data-model migration (v1-requirements §10; [[futures]]).
// Same fork conventions: `app_*`-mapped, the only hand-written satellite FK →
// core `"user"` is FocusDirective.declaredByUserId (drift-probed); every other
// edge is intra-Hub Prisma `@relation`.
// ─────────────────────────────────────────────────────────────────────────────

// The three focus layers compose: Phase = release-band (organisational,
// persistent), Sprint = week-of-work (org-wide, temporal), FocusDirective =
// in-conversation push (project-scoped, temporal). All three will feed
// `next-task` in v1.x.

enum SprintStatus {
  upcoming
  active
  complete
}

enum FocusDirectiveStatus {
  active
  expired
  superseded
}

enum PhaseStatus {
  upcoming
  active
  complete
  parked // structured ideas pool — visible, browseable, hidden from active views
}

// Org-wide sprint (not project-scoped, per §10). `planMarkdown` ingests an
// existing markdown sprint plan.
model Sprint {
  id           String       @id @default(cuid())
  name         String
  startDate    DateTime
  endDate      DateTime
  status       SprintStatus @default(upcoming)
  planMarkdown String?      @db.Text
  createdAt    DateTime     @default(now())

  directives FocusDirective[]

  @@map("app_sprint")
}

// A time-bounded priority directive ("push toward Friday demo", "hold pending
// external"), scoped to a project and optionally a sprint.
model FocusDirective {
  id               String               @id @default(cuid())
  projectId        String
  sprintId         String? // intra-Hub FK → app_sprint · ON DELETE SET NULL (directive outlives the sprint)
  declaredByUserId String? // hand-FK → "user" · ON DELETE SET NULL (retain the directive, drop the declarer)
  intent           String
  declaredAt       DateTime             @default(now())
  deadline         DateTime?
  reason           String? // for hold states — "until Angus gets back to us"
  status           FocusDirectiveStatus @default(active)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint  Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([sprintId])
  @@index([declaredByUserId])
  @@map("app_focus_directive")
}

// The epic layer above Feature: a release boundary or a `parked` future-work
// pool. Coarse and organisational — does NOT gate feature ordering or
// dependency (exploratory-ordering holds at the feature level).
model Phase {
  id          String      @id @default(cuid())
  projectId   String
  ordinal     Int // display order within the project
  name        String
  description String?     @db.Text
  status      PhaseStatus @default(upcoming)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  features Feature[] // Feature.phaseId · ON DELETE SET NULL (phase membership is optional)

  @@index([projectId])
  @@map("app_phase")
}
